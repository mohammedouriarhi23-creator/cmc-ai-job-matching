DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@localhost:5432/DATABASE

SECRET_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cle API Gemini (https://aistudio.google.com/apikey) pour l'extraction automatique
# de CV. Laisser vide pour desactiver la fonctionnalite (503 explicite renvoye).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Dossier de stockage privé des documents candidats
CANDIDATE_STORAGE_PATH=storage/candidate_documents
